APP_NAME=ConnectArena

# Twilio account credentials
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token

# Option 1: Twilio Verify for SMS OTP
TWILIO_VERIFY_SERVICE_SID=

# Option 2: Direct Twilio Messaging SMS OTP
# Example sender: +1234567890 or approved alphanumeric sender ID where supported
TWILIO_SMS_FROM=MyCompany

# Option 3: Twilio WhatsApp OTP
# Use a WhatsApp-enabled sender like whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Required when using the current WhatsApp template-based flow
TWILIO_WHATSAPP_CONTENT_SID=

# Email OTP via Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
